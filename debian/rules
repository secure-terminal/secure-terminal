#!/usr/bin/make -f

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## No --with python3: dh_python3 rewrites the "#!/usr/bin/python3 -Bsu" shebang
## (dropping -Bsu) and byte-compiles the module to .pyc at install time. We want
## neither -- the launcher runs with -B so no bytecode cache is ever written --
## so the module is shipped as plain .py via debian/install and dependencies are
## declared explicitly in debian/control.
%:
	dh $@

## Bake the version from debian/changelog into a file the app reads at runtime,
## straight into the staging tree so the source stays pristine.
execute_after_dh_install:
	install -d debian/secure-terminal/usr/share/secure-terminal
	dpkg-parsechangelog -S Version \
		> debian/secure-terminal/usr/share/secure-terminal/version
	## Compile the opt-in restricted CLI terminfo entry at build time, next to its
	## source, so an installed system need not run tic at runtime (the app falls
	## back to compiling into the user cache only for a source checkout).
	tic -x -o debian/secure-terminal/usr/share/secure-terminal/terminfo \
		debian/secure-terminal/usr/share/secure-terminal/terminfo/secure-terminal.ti

## Generate the man page from its ronn source at build time (reproducible date),
## the same way derivative-maker packages do, then let dh_installman install it.
override_dh_installman:
	mkdir --parents auto-generated-man-pages
	ronn \
		--date=2020-01-01 \
		--manual="secure-terminal Manual" \
		--organization="secure-terminal" \
		-- \
		<man/secure-terminal.1.ronn \
		>auto-generated-man-pages/secure-terminal.1
	ronn \
		--date=2020-01-01 \
		--manual="secure-terminal Manual" \
		--organization="secure-terminal" \
		-- \
		<man/secure-terminal-cli.1.ronn \
		>auto-generated-man-pages/secure-terminal-cli.1
	dh_installman auto-generated-man-pages/secure-terminal.1 \
		auto-generated-man-pages/secure-terminal-cli.1

## Remove the generated man page so the source tree stays pristine.
override_dh_clean:
	dh_clean
	rm --recursive --force auto-generated-man-pages

## Register the AppArmor profile and reload it on install/upgrade (and handle
## removal), via debhelper's dh_apparmor.
override_dh_installdeb:
	dh_installdeb
	dh_apparmor --profile-name=secure-terminal

## Ship the upstream git history as the upstream changelog, the way
## derivative-maker packages do (changelog.upstream is regenerated at release).
override_dh_installchangelogs:
	dh_installchangelogs changelog.upstream upstream
