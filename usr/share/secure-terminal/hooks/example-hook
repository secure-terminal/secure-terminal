#!/usr/bin/python3 -Bsu

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

"""
Example secure-terminal command hook.

secure-terminal ships no policy and no AI; this is a sample handler you point it
at. Enable it with a settings drop-in, e.g. ~/.config/secure-terminal.d/50_user.conf:

    command_hook=/usr/share/secure-terminal/hooks/example-hook
    command_hook_on_error=allow
    command_hook_transcript=none

The protocol (see secure_terminal.hook):
  - stdin  is a JSON request:  {"version":1,"command":..,"cwd":..,"tab":..,
                                "transcript":..?}
  - stdout is a JSON verdict:  {"verdict":"allow|block|ask|need_transcript",
                                "message":..?,"suggestion":..?}

This example uses only local rules (no network, fast). To judge with an AI
instead, replace decide() with a call that pipes the command to your model, e.g.
`claude --print`, and parse its answer -- keeping that logic HERE, out of the
terminal. Return need_transcript on the first pass to have secure-terminal call
you again with the scrollback attached (the cheap-then-escalate pattern), so the
long/expensive/injection-prone transcript is only sent when you actually need it.
"""

import os
import sys
import json
import re

# hooklib (sibling file) loads the rules from the drop-in tiers, so the allow /
# block / ask policy is documented, editable configuration -- not baked-in code.
sys.path.insert(0, os.path.dirname(os.path.realpath(__file__)))
import hooklib          # noqa: E402  pylint: disable=wrong-import-position

# The DEFAULT rules (verdict, regex, message, suggestion). An admin (or a user,
# if allowed) documents/edits them in example-hook-rules.conf. Piping a
# downloaded script into a privileged shell is the classic supply-chain footgun.
_DEFAULT_RULES = [
    ('block', r'\b(curl|wget|fetch)\b.*\|\s*sudo\s+(ba)?sh\b',
     'Refusing to pipe a downloaded script into a root shell.', ''),
    ('ask', r'\b(curl|wget|fetch)\b.*\|\s*(ba)?sh\b',
     'This pipes a downloaded script straight into a shell. Read it first.', ''),
    # Untrusted file -> shell: the same footgun as curl|sh but for a file you
    # already have (viewing "install docs" then piping them into a shell). A
    # homoglyph/bidi/hidden-byte doc could carry commands you never read.
    ('block', r'\b(cat|tac|zcat|xzcat|bzcat|head|tail|xxd|base64|dd)\b.*\|\s*sudo\s+(ba)?sh\b',
     'Refusing to pipe a file straight into a root shell -- its contents would run as root.', ''),
    ('ask', r'\b(cat|tac|zcat|xzcat|bzcat|head|tail|xxd|base64|dd)\b.*\|\s*(ba)?sh\b',
     'This pipes a file straight into a shell -- its contents run as commands. Read it first.', ''),
    ('ask', r'\b(ba)?sh\b\s+<\(',
     'This runs the output of a command as a script (process substitution). Read it first.', ''),
    ('ask', r'\bgit\s+push\b.*(--force|(\s|=)-f\b)',
     'A force-push can overwrite history on the remote.', ''),
    ('ask', r'^\s*sudo\b', 'This runs with root privileges.', ''),
]


def _load_rules():
    source = hooklib.read_rules('example-hook-rules.conf')
    if source is None:
        source = _DEFAULT_RULES
    compiled = []
    for verdict, pattern, message, suggestion in source:
        try:
            compiled.append((verdict, re.compile(pattern), message, suggestion))
        except re.error:
            continue                 # skip a malformed custom pattern
    if not compiled:                 # a wholly-bad file -> fall back to defaults
        compiled = [(v, re.compile(p), m, s) for v, p, m, s in _DEFAULT_RULES]
    return compiled


_RULES = _load_rules()


def decide(command):
    for verdict, pattern, message, suggestion in _RULES:
        if pattern.search(command):
            return {'verdict': verdict, 'message': message,
                    'suggestion': suggestion}
    return {'verdict': 'allow'}


def main():
    try:
        request = json.load(sys.stdin)
    except (ValueError, OSError):
        # a malformed request -> allow (secure-terminal also fails open by
        # default); never crash, never block the user's terminal on a bug here.
        print(json.dumps({'verdict': 'allow'}))
        return 0
    command = request.get('command', '') if isinstance(request, dict) else ''
    print(json.dumps(decide(command)))
    return 0


if __name__ == '__main__':
    sys.exit(main())
